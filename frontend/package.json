{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run check:base-sync && npm run i18n:generate-module && npm run check:menu-contract && npm run check:i18n-missing-keys && npm run check:i18n-hardcode && npm run check:shell-visual-contract && npm run check:system-page-admission && npm run check:smoke-web-base && npm run check:smoke-coverage-contract",
    "build": "tsc -b && vite build",
    "sync:base-shared": "node ./scripts/sync-base-shared.mjs",
    "check:base-sync": "node ./scripts/sync-base-shared.mjs --check",
    "i18n:generate-module": "node ./scripts/generate-module-i18n.mjs",
    "check:i18n-generated": "node ./scripts/generate-module-i18n.mjs --check",
    "check:menu-contract": "node ./scripts/check-menu-contract.mjs",
    "check:i18n-missing-keys": "node ./scripts/check-i18n-missing-keys.mjs",
    "check:i18n-hardcode": "node ./scripts/check-i18n-hardcode.mjs",
    "check:shell-visual-contract": "node ./scripts/check-shell-visual-contract.mjs",
    "check:system-page-admission": "node ./scripts/check-system-page-admission.mjs",
    "check:smoke-web-base": "node ./scripts/check-smoke-web-base.mjs",
    "check:smoke-coverage-contract": "node ./scripts/check-smoke-coverage-contract.mjs",
    "test:smoke:scripts": "node --test ./scripts/run-smoke-suite.test.mjs ./scripts/generate-module-i18n.test.mjs ./scripts/load-resource-module.test.mjs",
    "test:generator:dashboard-widget": "node ./scripts/run-generator-dashboard-widget-test.mjs",
    "test:generator:quality": "node ./scripts/run-generator-quality-contract-test.mjs",
    "test:generator:smoke": "npm run test:generator:dashboard-widget && npm run test:generator:quality && npm run check:menu-contract && npm run check:i18n-generated && npm run check:i18n-missing-keys && npm run check:i18n-hardcode",
    "audit:i18n-locales": "node ./scripts/audit-i18n-locales.mjs",
    "type-check": "tsc -b",
    "export:i18n-builtin-snapshot": "cd .. && node frontend/scripts/export-i18n-builtin-snapshot.mjs",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "audit": "npm audit --registry=https://registry.npmjs.org --audit-level=high",
    "preview": "vite preview",
    "test:smoke:platform": "npm run test:smoke:platform:contracts && npm run test:smoke:platform:surfaces && npm run test:smoke:platform:full",
    "test:smoke:platform:contracts": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/shell-visual-contract.spec.ts tests/smoke/auth/login-language-preference.spec.ts --workers=1",
    "test:smoke:platform:surfaces": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/platform-shell.spec.ts tests/smoke/platform/backoffice-ui-visual.spec.ts tests/smoke/platform/system-secondary-route-visual.spec.ts tests/smoke/system/system-form-state-matrix.spec.ts --workers=1",
    "test:smoke:platform:shell:preserve": "set PANTHEON_SMOKE_PRESERVE_FIXTURES=1&& node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/platform-shell.spec.ts --workers=1",
    "smoke:preserve:platform-shell": "npm run test:smoke:platform:shell:preserve",
    "test:smoke:platform:full": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --config playwright.full-system.config.ts -- tests/smoke/platform/full-system-pages.spec.ts",
    "test:smoke:system": "npm run test:smoke:system:pages && npm run test:smoke:system:iam-authz && npm run test:smoke:system:governance && npm run test:smoke:system:api",
    "test:smoke:system:pages": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/system/system-pages.spec.ts",
    "test:smoke:system:pages:preserve": "set PANTHEON_SMOKE_PRESERVE_FIXTURES=1&& npm run test:smoke:system:pages",
    "smoke:preserve:system-pages": "npm run test:smoke:system:pages:preserve",
    "test:smoke:system:iam-authz": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/system/role-authorization.spec.ts",
    "test:smoke:system:governance": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/system/governance/system-governance-action-matrix.spec.ts tests/smoke/system/governance/governance-insight-drawer.spec.ts tests/smoke/system/governance/permission-workbench-remediation.spec.ts tests/smoke/system/governance/permission-workbench-remediation-real.spec.ts tests/smoke/system/governance/module-governance.spec.ts tests/smoke/system/governance/module-governance-real.spec.ts tests/smoke/system/governance/module-governance-host-real.spec.ts tests/smoke/system/governance/cleanup-range-ui.spec.ts --workers=1",
    "test:smoke:system:generator-workbench": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/system/governance/module-governance.spec.ts --grep \"generator workbench entry\"",
    "test:smoke:system:module-governance-host": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --setup scripts/database-import-qa-setup.mjs --config playwright.config.ts -- tests/smoke/system/governance/module-governance-host-real.spec.ts",
    "test:smoke:system:api": "playwright test tests/smoke/system/api/system-import-export.spec.ts tests/smoke/system/api/system-batch-delete.spec.ts --config=playwright.api.config.ts",
    "test:smoke:business": "npm run test:smoke:business:cmdb && npm run test:smoke:business:deploy && npm run test:smoke:business:master-detail && npm run test:smoke:business:many-to-many && npm run test:smoke:business:auto-recycle",
    "test:smoke:business:cmdb": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/business/cmdb/cmdb-pages.spec.ts",
    "test:smoke:business:deploy": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/business/deploy/deploy-pages.spec.ts",
    "test:smoke:business:master-detail": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --setup scripts/master-detail-qa-setup.mjs --config playwright.master-detail.config.ts -- tests/smoke/system/governance/module-master-detail-real.spec.ts",
    "test:smoke:business:many-to-many": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --setup scripts/many-to-many-qa-setup.mjs --config playwright.many-to-many.config.ts -- tests/smoke/system/governance/module-many-to-many-real.spec.ts",
    "test:smoke:business:auto-recycle": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --setup scripts/auto-recycle-qa-setup.mjs --config playwright.auto-recycle.config.ts -- tests/smoke/system/governance/module-auto-recycle-real.spec.ts",
    "test:smoke:all": "npm run test:smoke:platform && npm run test:smoke:system && npm run test:smoke:business",
    "smoke:preserve": "npm run smoke:preserve:system-pages",
    "smoke:cleanup": "node scripts/cleanup-smoke-fixtures.mjs",
    "smoke:cleanup:iam": "node scripts/cleanup-smoke-fixtures.mjs --scope iam",
    "smoke:cleanup:org": "node scripts/cleanup-smoke-fixtures.mjs --scope org",
    "smoke:cleanup:config": "node scripts/cleanup-smoke-fixtures.mjs --scope config",
    "test:smoke:role-auth": "npm run test:smoke:system:iam-authz",
    "test:smoke:shell-visual-contract": "npm run test:smoke:platform:contracts",
    "test:smoke:backoffice-ui": "npm run test:smoke:platform:surfaces",
    "test:smoke:impexp": "npm run test:smoke:system:api",
    "test:smoke:module-governance-host": "npm run test:smoke:system:module-governance-host",
    "test:smoke:generator-workbench": "npm run test:smoke:system:generator-workbench",
    "test:smoke:full-system": "npm run test:smoke:platform:full"
  },
  "dependencies": {
    "@arco-design/web-react": "*",
    "axios": "^1.17.0",
    "i18next": "*",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "*",
    "react-router-dom": "*",
    "zustand": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
