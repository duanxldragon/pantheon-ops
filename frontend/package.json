{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run i18n:generate-module && npm run check:menu-contract && npm run check:i18n-missing-keys && npm run check:i18n-hardcode && npm run check:shell-visual-contract",
    "build": "tsc -b && vite build",
    "i18n:generate-module": "node ./scripts/generate-module-i18n.mjs",
    "check:i18n-generated": "node ./scripts/generate-module-i18n.mjs --check",
    "check:menu-contract": "node ./scripts/check-menu-contract.mjs",
    "check:i18n-missing-keys": "node ./scripts/check-i18n-missing-keys.mjs",
    "check:i18n-hardcode": "node ./scripts/check-i18n-hardcode.mjs",
    "check:shell-visual-contract": "node ./scripts/check-shell-visual-contract.mjs",
    "test:generator:dashboard-widget": "node ./scripts/run-generator-dashboard-widget-test.mjs",
    "test:generator:quality": "node ./scripts/run-generator-quality-contract-test.mjs",
    "test:generator:smoke": "npm run test:generator:dashboard-widget && npm run test:generator:quality && npm run check:menu-contract && npm run check:i18n-generated && npm run check:i18n-missing-keys && npm run check:i18n-hardcode",
    "audit:i18n-locales": "node ./scripts/audit-i18n-locales.mjs",
    "type-check": "tsc -b",
    "export:i18n-builtin-snapshot": "cd .. && node frontend/scripts/export-i18n-builtin-snapshot.mjs",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "audit": "npm audit --registry=https://registry.npmjs.org --audit-level=high",
    "preview": "vite preview",
    "test:smoke:system": "npm run test:smoke:system:pages && npm run test:smoke:system:auth && npm run test:smoke:system:shell && npm run test:smoke:system:ui && npm run test:smoke:system:governance && npm run test:smoke:system:api",
    "test:smoke:system:pages": "playwright test tests/smoke/system/system-pages.spec.ts --config=playwright.config.ts",
    "test:smoke:system:auth": "playwright test tests/smoke/system/role-authorization.spec.ts --config=playwright.config.ts",
    "test:smoke:system:shell": "playwright test tests/smoke/platform/shell-visual-contract.spec.ts tests/smoke/platform/platform-shell.spec.ts --config=playwright.config.ts --workers=1",
    "test:smoke:system:ui": "playwright test tests/smoke/platform/backoffice-ui-visual.spec.ts tests/smoke/system/system-form-state-matrix.spec.ts --config=playwright.config.ts --workers=1",
    "test:smoke:system:governance": "playwright test tests/smoke/system/governance/system-governance-action-matrix.spec.ts tests/smoke/system/governance/governance-insight-drawer.spec.ts tests/smoke/system/governance/permission-workbench-remediation.spec.ts tests/smoke/system/governance/permission-workbench-remediation-real.spec.ts tests/smoke/system/governance/module-governance.spec.ts tests/smoke/system/governance/module-governance-real.spec.ts tests/smoke/system/governance/module-governance-host-real.spec.ts --config=playwright.config.ts --workers=1",
    "test:smoke:system:generator-workbench": "playwright test tests/smoke/system/governance/module-governance.spec.ts --grep \"generator workbench entry\" --config=playwright.config.ts",
    "test:smoke:system:module-governance-host": "playwright test tests/smoke/system/governance/module-governance-host-real.spec.ts --config=playwright.config.ts",
    "test:smoke:system:api": "playwright test tests/smoke/system/api --config=playwright.api.config.ts",
    "test:smoke:system:full": "playwright test tests/smoke/platform/full-system-pages.spec.ts --config=playwright.full-system.config.ts",
    "test:smoke:business": "npm run test:smoke:business:cmdb && npm run test:smoke:business:deploy",
    "test:smoke:business:cmdb": "playwright test tests/smoke/business/cmdb/cmdb-pages.spec.ts --config=playwright.config.ts",
    "test:smoke:business:deploy": "playwright test tests/smoke/business/deploy/deploy-pages.spec.ts --config=playwright.config.ts",
    "test:smoke:all": "npm run test:smoke:system && npm run test:smoke:business",
    "test:smoke:role-auth": "npm run test:smoke:system:auth",
    "test:smoke:shell-visual-contract": "npm run test:smoke:system:shell",
    "test:smoke:backoffice-ui": "npm run test:smoke:system:ui",
    "test:smoke:impexp": "npm run test:smoke:system:api",
    "test:smoke:module-governance-host": "npm run test:smoke:system:module-governance-host",
    "test:smoke:generator-workbench": "npm run test:smoke:system:generator-workbench",
    "test:smoke:full-system": "npm run test:smoke:system:full"
  },
  "dependencies": {
    "@arco-design/web-react": "*",
    "axios": "^1.16.0",
    "i18next": "*",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "*",
    "react-router-dom": "*",
    "zustand": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jszip": "^3.10.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12"
  }
}
