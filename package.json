{
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run check:base-sync",
    "apply:github-feedback": "node scripts/address-github-feedback.mjs",
    "run:github-feedback-loop": "node scripts/run-github-feedback-loop.mjs",
    "test:branch-hygiene": "node --test tests/scripts/cleanup-github-branches.test.mjs tests/scripts/branch-hygiene-workflow.test.mjs",
    "check:duplication": "node scripts/check-duplication.mjs",
    "check:github-feedback": "node scripts/fetch-github-feedback.mjs --check",
    "check:base-sync": "node scripts/check-base-backend-sync.mjs && npm --prefix frontend run check:base-sync",
    "check:base-sync:backend": "node scripts/check-base-backend-sync.mjs",
    "check:base-sync:frontend": "npm --prefix frontend run check:base-sync",
    "check:base-sync:workspace": "npm run check:base-sync:backend:workspace && npm run check:base-sync:frontend:workspace",
    "check:base-sync:backend:workspace": "node scripts/check-base-backend-sync.mjs --workspace-head",
    "check:base-sync:frontend:workspace": "npm --prefix frontend run check:base-sync:workspace",
    "check:inheritance": "npm run check:task-packet-template && npm run check:inheritance-contract && npm run check:base-sync:backend && npm run check:base-sync:frontend && npm run check:overlay-compile",
    "check:inheritance-contract": "node scripts/check-inheritance-contract.mjs",
    "check:docs-frontmatter": "node scripts/frontmatter-check.mjs",
    "check:pr-governance": "node scripts/check-pr-governance.mjs",
    "check:task-packet-template": "node scripts/check-task-packet-template.mjs",
    "check:generated-modules": "node frontend/scripts/cleanup-generated-modules.mjs --check",
    "check:overlay-compile": "node scripts/check-overlay-compile.mjs",
    "upgrade:foundation:plan": "node scripts/foundation-release/consume-foundation-release.mjs --dry-run",
    "upgrade:foundation:apply": "node scripts/foundation-release/consume-foundation-release.mjs --apply-shared-backend --apply-shared-frontend --update-inheritance-docs --check",
    "foundation:install": "node scripts/foundation-release/install-foundation-release.mjs",
    "upgrade:foundation:local-plan": "node scripts/foundation-release/upgrade-from-local-base-release.mjs --plan-only",
    "upgrade:foundation:local-apply": "node scripts/foundation-release/upgrade-from-local-base-release.mjs",
    "test:foundation-release": "node --test tests/scripts/**/*.test.mjs",
    "test:address-github-feedback": "node --test tests/scripts/address-github-feedback.test.mjs",
    "test:github-feedback": "node --test tests/scripts/fetch-github-feedback.test.mjs",
    "test:github-feedback-loop": "node --test tests/scripts/run-github-feedback-loop.test.mjs",
    "test:pr-automation-workflow": "node --test tests/scripts/pr-automation-workflow.test.mjs",
    "test:pr-governance": "node --test tests/scripts/check-pr-governance.test.mjs",
    "test:duplication": "node --test tests/scripts/check-duplication.test.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
